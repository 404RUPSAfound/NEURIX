# NEURIX SATELLITE TILE SERVICE - CONFIGURATION

# Server
PORT=3001
NODE_ENV=development

# NASA GIBS (Free / No Key Required for Standard Layers)
# Layers: VIIRS_SNPP_CorrectedReflectance_TrueColor, MODIS_Aqua_CorrectedReflectance_TrueColor

# Sentinel Hub (Copernicus Sentinel-2)
# Register at: https://www.sentinel-hub.com/ to get these keys.
SENTINEL_CLIENT_ID=your_client_id_here
SENTINEL_CLIENT_SECRET=your_client_secret_here
SENTINEL_INSTANCE_ID=your_instance_id_here

# Caching
CACHE_TTL=86400
CACHE_MAX_KEYS=1000

